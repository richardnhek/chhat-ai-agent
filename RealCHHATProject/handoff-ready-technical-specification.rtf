\f1\b\fs48 \cf0 \strokec2 6. Database schema draft\
\pard\pardeftab720\sa240\partightenfactor0

\f0\b0\fs24 \cf0 Below is a practical relational schema.\
\pard\pardeftab720\partightenfactor0

\f2\fs26 \cf0 create table jobs (\
  id uuid primary key,\
  client_id uuid not null,\
  source_type text not null,\
  status text not null,\
  created_by uuid,\
  created_at timestamptz not null default now(),\
  started_at timestamptz,\
  completed_at timestamptz,\
  priority int default 5,\
  config_version text\
);\
\
create table job_images (\
  id uuid primary key,\
  job_id uuid not null references jobs(id),\
  outlet_id text not null,\
  image_uri_raw text not null,\
  image_uri_normalized text,\
  thumbnail_uri text,\
  sha256 text,\
  phash text,\
  capture_timestamp timestamptz,\
  quality_status text,\
  quality_scores_json jsonb,\
  status text not null default 'queued'\
);\
\
create table detections (\
  id uuid primary key,\
  job_image_id uuid not null references job_images(id),\
  bbox_x1 int not null,\
  bbox_y1 int not null,\
  bbox_x2 int not null,\
  bbox_y2 int not null,\
  class_name text not null,\
  detector_version text not null,\
  detector_score numeric not null,\
  visible_fraction numeric,\
  crop_uri text\
);\
\
create table crop_predictions (\
  id uuid primary key,\
  detection_id uuid not null references detections(id),\
  ocr_text_raw text,\
  ocr_text_norm text,\
  ocr_score numeric,\
  retrieval_topk_json jsonb,\
  brand_logits_json jsonb,\
  sku_logits_json jsonb,\
  arbitrator_json jsonb,\
  final_brand text,\
  final_sku text,\
  final_confidence numeric,\
  review_required boolean not null default false,\
  decision_reason_code text,\
  pipeline_version text not null\
);\
\
create table review_tasks (\
  id uuid primary key,\
  crop_prediction_id uuid not null references crop_predictions(id),\
  assigned_to uuid,\
  status text not null default 'open',\
  sla_due_at timestamptz,\
  created_at timestamptz not null default now(),\
  closed_at timestamptz\
);\
\
create table review_events (\
  id uuid primary key,\
  review_task_id uuid not null references review_tasks(id),\
  reviewer_id uuid not null,\
  old_brand text,\
  old_sku text,\
  new_brand text,\
  new_sku text,\
  reason_code text not null,\
  notes text,\
  created_at timestamptz not null default now()\
);\
\
create table catalog_brands (\
  id uuid primary key,\
  mother_brand text not null unique,\
  brand_code text not null unique,\
  active boolean not null default true\
);\
\
create table catalog_skus (\
  id uuid primary key,\
  brand_id uuid not null references catalog_brands(id),\
  sku_code text not null unique,\
  sku_name text not null,\
  pack_size text,\
  warning_variant text,\
  packaging_generation text,\
  aliases_json jsonb,\
  active_from date,\
  active_to date,\
  is_active boolean not null default true\
);\
\
create table catalog_assets (\
  id uuid primary key,\
  sku_id uuid not null references catalog_skus(id),\
  view_type text not null,\
  image_uri text not null,\
  ocr_reference_text text,\
  is_primary boolean not null default false\
);\
\
create table model_registry (\
  id uuid primary key,\
  model_type text not null,\
  version text not null unique,\
  artifact_uri text not null,\
  metrics_json jsonb,\
  deployed_at timestamptz,\
  status text not null\
);\
\
create table exports (\
  id uuid primary key,\
  job_id uuid not null references jobs(id),\
  export_uri text not null,\
  format text not null,\
  generated_at timestamptz not null default now()\
);\
\pard\pardeftab720\sa240\partightenfactor0

\f0\fs24 \cf0 For vector retrieval, add pgvector columns to 
\f2\fs26 catalog_assets
\f0\fs24  and optionally to cached crop embeddings; pgvector is specifically intended for vector similarity search and embeddings inside Postgres. ({\field{\*\fldinst{HYPERLINK "https://supabase.com/docs/guides/database/extensions/pgvector"}}{\fldrslt \cf4 \ul \ulc4 \strokec4 Supabase}})\
